# MySky Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Supabase Configuration (REQUIRED)
# Get these from https://supabase.com/dashboard/project/[YOUR_PROJECT_ID]/settings/api
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGc...

# Sentry Error Monitoring (REQUIRED)
# Get from https://sentry.io/settings/account/projects/
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.us.sentry.io/0

# RevenueCat In-App Purchases (OPTIONAL - required for iOS purchases)
# Get from https://app.revenuecat.com/settings/api-keys
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_XxXxXxXxXxXxXxXxXx
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_XxXxXxXxXxXxXxXxXx
EXPO_PUBLIC_REVENUECAT_ALLOW_DEV_BUNDLE=false

# Build Variant
APP_VARIANT=development
NODE_ENV=development

EXPO_PUBLIC_REFLECTION_INSIGHTS_URL=https://your-project.supabase.co/functions/v1/reflection-insights
SENTRY_AUTH_TOKEN=your_sentry_auth_token
# GEMINI_API_KEY is a server-side secret — set it with:
#   supabase secrets set GEMINI_API_KEY=AIza...
# It is NOT an EXPO_PUBLIC_ variable and must never be in the client bundle.
