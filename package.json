{
  "name": "mysky",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "dev:tunnel": "expo start --dev-client --tunnel",
    "dev:lan": "expo start --dev-client --lan",
    "reset-project": "node ./scripts/reset-project.js",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "ios:sim": "expo run:ios --simulator",
    "web": "expo start --web",
    "update:preview": "eas update --platform ios --channel preview",
    "update:production": "eas update --platform ios --channel production",
    "lint": "expo lint",
    "test": "jest",
    "test:components": "jest --config jest.component.config.js",
    "test:all": "npm test && npm run test:components",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "postinstall": "patch-package",
    "android": "expo run:android"
  },
