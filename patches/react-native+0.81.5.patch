+  // iOS 26 (New Architecture): NSException.callStackSymbols and callStackReturnAddresses
+  // use _NSCallStackArray which lazily calls backtrace_symbols/dladdr per element.
+  // On iOS 26 the call stack can contain null (0x0) addresses; dladdr(0x0) crashes
+  // with SIGSEGV inside ObjCTurboModule::performVoidMethodInvocation.
+  // Guard both accesses so the exception message is still surfaced even if symbolication fails.
+  @try {
+    cause.setProperty(runtime, "stackSymbols", convertNSArrayToJSIArray(runtime, exception.callStackSymbols));
+  } @catch (...) {}
+  @try {
+    cause.setProperty(
